<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_login">

    <!-- Auth screens (no bottom nav) -->

    <fragment
        android:id="@+id/nav_login"
        android:name="com.example.smartpantry.ui.fragments.LoginFragment"
        android:label="@string/title_login">

        <action
            android:id="@+id/action_nav_login_to_nav_create_account"
            app:destination="@id/nav_create_account"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />

        <action
            android:id="@+id/action_nav_login_to_nav_home"
            app:destination="@id/nav_home"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popUpTo="@id/nav_login"
            app:popUpToInclusive="true" />

    </fragment>

    <fragment
        android:id="@+id/nav_create_account"
        android:name="com.example.smartpantry.ui.fragments.CreateAccountFragment"
        android:label="@string/title_create_account">

        <action
            android:id="@+id/action_nav_create_account_to_nav_home"
            app:destination="@id/nav_home"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popUpTo="@id/nav_login"
            app:popUpToInclusive="true" />

    </fragment>

    <!-- Main app screens (with bottom nav) -->

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.smartpantry.ui.fragments.HomeFragment"
        android:label="@string/tab_home">

        <action
            android:id="@+id/action_nav_home_to_nav_settings"
            app:destination="@id/nav_settings"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />

    </fragment>

    <fragment
        android:id="@+id/nav_pantry"
        android:name="com.example.smartpantry.ui.fragments.PantryFragment"
        android:label="@string/tab_pantry" />

    <fragment
        android:id="@+id/nav_recipes"
        android:name="com.example.smartpantry.ui.fragments.RecipesFragment"
        android:label="@string/tab_recipes">

        <action
            android:id="@+id/action_nav_recipes_to_nav_add_recipe"
            app:destination="@id/nav_add_recipe"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />

        <action
            android:id="@+id/action_nav_recipes_to_nav_recipe_detail"
            app:destination="@id/nav_recipe_detail"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />

    </fragment>

    <fragment
        android:id="@+id/nav_add_recipe"
        android:name="com.example.smartpantry.ui.fragments.AddRecipeFragment"
        android:label="@string/title_add_recipe" />

    <fragment
        android:id="@+id/nav_recipe_detail"
        android:name="com.example.smartpantry.ui.fragments.RecipeDetailFragment"
        android:label="@string/title_recipe_detail" />

    <fragment
        android:id="@+id/nav_chat"
        android:name="com.example.smartpantry.ui.fragments.ChatFragment"
        android:label="@string/tab_chat" />

    <fragment
        android:id="@+id/nav_settings"
        android:name="com.example.smartpantry.ui.fragments.SettingsFragment"
        android:label="@string/title_settings" />

    <!-- Global action to navigate back to login (used by logout) -->
    <action
        android:id="@+id/action_global_nav_login"
        app:destination="@id/nav_login"
        app:popUpTo="@id/nav_graph"
        app:popUpToInclusive="true"
        app:enterAnim="@anim/nav_default_enter_anim"
        app:exitAnim="@anim/nav_default_exit_anim" />

</navigation>
